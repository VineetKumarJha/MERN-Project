<% layout("/layouts/boilerplate") %>
<body>
    
    <form method="POST" action="/listings/<%=idList._id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="row mt-3">
            <h3>Edit details below</h3>
            <div class="col-8 offset-1">
                <div class="mb-3">
                    <label for="title" class="form-label"></label>Title</label>
                    <input type="text" name="listing[title]" value="<%=idList.title%>" class="form-control" required>
                    <div class="valid-feedback">Tittle looks good!</div>
                </div>
                
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" rows="3" cols="20" class="form-control" required><%=idList.description%></textarea>
                    <div class="invalid-feedback">Enter a short description</div>
                </div>

                <div class="mb-3">
                    <p><b>Original Listing Image</b> </p>
                    <img style="height: 200px; width:400px;" src="<%=originalImageUrl%>">
                </div>
                
                <div class="mb-3 ">
                    <label for="url" class="form-label">Upload New Image</label>
                    <input type="file" name="listing[image][url]" value="<%=idList.image%>" class="form-control">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" name="listing[price]" value="<%=idList.price%>" class="form-control" required>
                        <div class="invalid-feedback">Price should be valid</div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" value="<%=idList.country%>" class="form-control" required>
                        <div class="invalid-feedback">Country name should be valid</div>
                    </div>
                </div>
                

                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" value="<%=idList.location%>" class="form-control" required>
                    <div class="invalid-feedback">Please enter a valid location</div>
                </div>
                 
                
                <button class="btn btn-dark edit-btn mt-3">Push Changes</button>
                <br><br>
            </form>
        </div>
    </div>
</body>