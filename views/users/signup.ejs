<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-8 offset-3 mb-3">SignUp for Wanderlust</h1>
    <div class="col-8 offset-3">
        <form method="POST" action="/signup" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" id="username" name="username" placeholder="Add username" class="form-control" required>
                <div class="valid-feedback">Please add username</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" placeholder="Add email" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" placeholder="Add password" class="form-control" required>
            </div>

            <button class="btn btn-success">SignUp</button>
        </form>
    </div>
</div>